    "numeric_cols = ['T2M', 'T2M_MAX', 'T2M_MIN', 'T2M_RANGE', 'PRECTOTCORR', \n",
    "                'RH2M', 'WS2M', 'WS2M_MAX', 'PS', 'QV2M']\n",
